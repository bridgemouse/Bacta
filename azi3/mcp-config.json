{
  "mcpServers": {
    "vault-query": {
      "command": "python3",
      "args": ["/opt/bacta/azi3/vault_query_server.py"],
      "env": {
        "VAULT_WIKI_ROOT": "/mnt/vault/wiki"
      }
    },
    "bacta-db": {
      "command": "python3",
      "args": ["/opt/bacta/azi3/db_query_server.py"],
      "env": {
        "DB_PATH": "/opt/bacta/data/bacta.db"
      }
    }
  }
}
